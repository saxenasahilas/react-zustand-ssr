{
  "name": "zustand-ssr",
  "version": "0.1.0",
  "type": "module",
  "description": "Solve Zustand persist middleware SSR hydration mismatches in Next.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/saxenasahilas/react-zustand-ssr.git"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./useHydrated": {
      "types": "./dist/useHydrated.d.ts",
      "import": "./dist/useHydrated.js",
      "require": "./dist/useHydrated.cjs",
      "default": "./dist/useHydrated.js"
    },
    "./createHydratedStore": {
      "types": "./dist/createHydratedStore.d.ts",
      "import": "./dist/createHydratedStore.js",
      "require": "./dist/createHydratedStore.cjs",
      "default": "./dist/createHydratedStore.js"
    },
    "./createHydratedStoreContext": {
      "types": "./dist/createHydratedStoreContext.d.ts",
      "import": "./dist/createHydratedStoreContext.js",
      "require": "./dist/createHydratedStoreContext.cjs",
      "default": "./dist/createHydratedStoreContext.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/useHydrated.ts src/createHydratedStore.ts src/createHydratedStoreContext.ts --format cjs,esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "zustand": ">=5.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/react": "^18.0.0",
    "happy-dom": "^20.9.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "zustand": "^5.0.0"
  }
}
